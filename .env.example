# ──────────────────────────────────────────────────────────────────────────────
# Falcon Security AI Microservice — Configuration
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Service identity ──────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000

# ── NestJS backend (where alerts are POSTed) ──────────────────────────────────
# The AI service calls POST {NESTJS_API_URL}/ingest/ai-alert
NESTJS_API_URL=http://localhost:3000/api/v1
# Service-to-service API key — add a matching header check in NestJS if needed
NESTJS_SERVICE_KEY=falcon_internal_service_key_change_in_production

# ── YOLOv8 model ─────────────────────────────────────────────────────────────
# Path to the .pt weights file.  Set to "mock" to use the built-in mock.
MODEL_PATH=mock
# Confidence threshold — detections below this are ignored
CONFIDENCE_THRESHOLD=0.50
# IoU threshold for non-max suppression
IOU_THRESHOLD=0.45
# Classes that trigger an ALERT (comma-separated COCO / custom class names)
ALERT_CLASSES=knife,gun,pistol,rifle,fight,weapon,fire,smoke

# ── Performance ──────────────────────────────────────────────────────────────
# Max image dimension before downscaling (keeps inference fast on edge hardware)
MAX_IMAGE_SIZE=1280
# Number of Uvicorn worker processes (set to 1 on edge hardware)
WORKERS=1
